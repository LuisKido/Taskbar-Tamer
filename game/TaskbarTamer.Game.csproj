<Project Sdk="Godot.NET.Sdk/4.6.3">

  <!--
    Cliente Godot. Referencia a core/ (la lógica pura del juego).
    TargetFramework net8.0 = el que usa Godot 4.6.
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <RootNamespace>TaskbarTamer.Game</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\core\TaskbarTamer.Core.csproj" />
  </ItemGroup>

</Project>
