; Configuración del proyecto Godot — Taskbar Tamer
; Generado a mano; el editor puede reordenar/ampliar al abrir.

config_version=5

[application]

config/name="Taskbar Tamer"
run/main_scene="res://Scenes/Main.tscn"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")

[dotnet]

project/assembly_name="TaskbarTamer.Game"

[display]

; Ventana compacta, sin bordes y siempre encima: el usuario la mueve donde quiera.
window/size/viewport_width=420
window/size/viewport_height=540
window/size/borderless=true
window/size/always_on_top=true
window/size/transparent=false

[rendering]

; Renderer ligero para bajo consumo en idle.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
