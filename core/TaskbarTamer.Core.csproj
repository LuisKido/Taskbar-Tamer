<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Núcleo de simulación. C# PURO: sin referencias a Godot ni a red.
    Lo referencian tanto game/ (cliente Godot) como server/ (futuro).
    TargetFramework net8.0 = compatible con Godot 4.x .NET.
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>TaskbarTamer.Core</RootNamespace>
    <AssemblyName>TaskbarTamer.Core</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

</Project>
